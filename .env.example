# Optional for small requests; recommended for higher NCBI rate limits.
NCBI_API_KEY=
NCBI_EMAIL=

# B can use this when the chatbot service is connected.
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=change-this-before-deployment
PUBMED_DB_PATH=pubmed.db
# Set true on a public HTTPS deployment; keep false for local development.
HTTPS_ONLY=false
